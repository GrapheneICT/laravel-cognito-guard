{
    "name": "graphene-ict/laravel-cognito-guard",
    "description": "Lean Laravel auth guard that validates AWS Cognito User Pool JWTs. Supports DB-backed users, DB-less mode, cognito:groups → Gates bridge, multi-pool, and Octane.",
    "keywords": [
        "GrapheneICT",
        "laravel",
        "laravel-cognito-guard",
        "aws-cognito",
        "jwt",
        "oidc",
        "authentication",
        "guard"
    ],
    "homepage": "https://github.com/GrapheneICT/laravel-cognito-guard",
    "license": "MIT",
    "authors": [
        {
            "name": "Jovan Stojiljkovic",
            "email": "jstojiljkovic941@gmail.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/GrapheneICT/laravel-cognito-guard/issues",
        "source": "https://github.com/GrapheneICT/laravel-cognito-guard",
        "security": "https://github.com/GrapheneICT/laravel-cognito-guard/security/policy"
    },
    "require": {
        "php": "^8.3",
        "ext-openssl": "*",
        "firebase/php-jwt": "^6.10|^7.0",
        "illuminate/auth": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpseclib/phpseclib": "^3.0"
    },
    "suggest": {
        "laravel/octane": "Recommended for high-throughput APIs — this package is Octane-safe and ships with a state-leak test.",
        "laravel/sanctum": "For hybrid auth setups where some routes use Cognito JWTs and others use Sanctum personal-access-tokens."
    },
    "autoload": {
        "psr-4": {
            "GrapheneICT\\CognitoGuard\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GrapheneICT\\CognitoGuard\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "mutate": "vendor/bin/pest --mutate --covered-only",
        "format": "vendor/bin/pint",
        "format-check": "vendor/bin/pint --test"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.x-dev"
        },
        "laravel": {
            "providers": [
                "GrapheneICT\\CognitoGuard\\CognitoAuthServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
