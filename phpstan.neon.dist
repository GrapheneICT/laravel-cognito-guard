includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 8
    paths:
        - src
        - config
    tmpDir: build/phpstan
    checkOctaneCompatibility: true
    checkModelProperties: true
    ignoreErrors:
        # env() calls in a package's config file are the standard Laravel pattern;
        # the file gets republished into the host app's own config/ at install time.
        -
            identifier: larastan.noEnvCallsOutsideOfConfig
            path: config/*
